{{#> layout_default }}
    <h1>
        <span style="font-family: Arial, Helvetica, sans-serif; font-size: 24px">
            {{t "advocateRejected.hello"}}
        </span>
        <br />

        {{> user-name }}
    </h1>

    <table role="presentation" border="0" cellpadding="0" cellspacing="0">
        <tbody>
        <tr>
            <td align="left">
            <p>
                <strong></strong>{{t "advocateRejected.approvalMessage" appOptions}}
                <br/><br/>
                {{t "advocateRejected.approvalInfo"}}
                <br/><br/>
                <strong>{{t "advocateRejected.completeMessage"}}</strong>
            </p>
            </td>
        </tr>
        </tbody>
    </table>
{{/layout_default }}
